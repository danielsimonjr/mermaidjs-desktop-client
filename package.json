{
  "name": "mermaidjs-desktop-client",
  "version": "2.4.0",
  "description": "Desktop editor for Mermaid diagrams with real-time preview, syntax highlighting, and SVG/PNG export.",
  "homepage": "https://github.com/skydiver/mermaidjs-desktop-client",
  "repository": {
    "type": "git",
    "url": "https://github.com/skydiver/mermaidjs-desktop-client.git"
  },
  "license": "MIT",
  "author": {
    "name": "Martín M.",
    "email": "skydiver@users.noreply.github.com"
  },
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c auto \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "npm run build:electron && wait-on http://localhost:5173 && electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "package": "npm run clean && npm run build && electron-builder",
    "clean": "rimraf dist dist-electron release",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.3",
    "@codemirror/view": "^6.39.7",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "codemirror": "^6.0.2",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "happy-dom": "^20.9.0",
    "mermaid": "^11.12.2",
    "remixicon": "^4.7.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.1"
  }
}
